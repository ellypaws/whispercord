{
  "name": "vt-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host localhost",
    "build": "bun run build:app && bun run build:overlay",
    "build:app": "vite build",
    "build:overlay": "vite build --config vite.overlay.config.ts",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@preact/signals": "^2.0.5",
    "preact": "^10.26.9"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
