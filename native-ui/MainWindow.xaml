<Window
    x:Class="DiscordTranscriber.Native.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:DiscordTranscriber.Native.Models"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    Title="Discord Live Transcriber">

    <Grid x:Name="Root" Loaded="Root_Loaded">
        <Grid.Resources>
            <!-- One card template, reused for every panel in a UniformGrid so they evenly fill the width. -->
            <DataTemplate x:Key="PanelCardTemplate" x:DataType="models:TranscriptPanel">
                <Border Margin="6,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8">
                    <Grid RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Padding="14,10"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid ColumnSpacing="4" ColumnDefinitions="*,Auto,Auto,Auto">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Title}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="{Binding ActiveText}" Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding FinalCount}" VerticalAlignment="Center" Margin="0,0,4,0"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                <Button Grid.Column="2" Click="FlipPanel_Click" Tag="{Binding}"
                                        ToolTipService.ToolTip="Flip direction (newest top/bottom)">
                                    <FontIcon Glyph="&#xE8CB;" FontSize="14" />
                                </Button>
                                <Button Grid.Column="3" Click="ClearPanel_Click" Tag="{Binding}"
                                        ToolTipService.ToolTip="Clear transcript">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                </Button>
                            </Grid>
                        </Border>

                        <ListView Grid.Row="1" ItemsSource="{Binding Items}" SelectionMode="None" Padding="6,4">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:TranscriptItem">
                                    <Grid Padding="6,8" ColumnSpacing="12" ColumnDefinitions="Auto,*">
                                        <PersonPicture Grid.Column="0" Width="32" Height="32" VerticalAlignment="Top"
                                                       DisplayName="{Binding Name}"
                                                       ProfilePicture="{Binding Avatar, Converter={StaticResource AvatarImageConverter}}" />
                                        <StackPanel Grid.Column="1" Spacing="1">
                                            <Grid ColumnSpacing="8" ColumnDefinitions="*,Auto">
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStrongTextBlockStyle}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" Text="{Binding TimeText}" VerticalAlignment="Center"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                            </Grid>
                                            <TextBlock Text="{Binding Text}" TextWrapping="WrapWholeWords"
                                                       IsTextSelectionEnabled="True"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </DataTemplate>
        </Grid.Resources>

        <NavigationView x:Name="Nav"
                        PaneDisplayMode="Left"
                        IsPaneOpen="False"
                        OpenPaneLength="200"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        SelectionChanged="Nav_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Live" Icon="Play" Tag="live" IsSelected="True" />
                <NavigationViewItem Content="Settings" Icon="Setting" Tag="settings" />
                <NavigationViewItem Content="Console" Icon="Document" Tag="console" />
            </NavigationView.MenuItems>

            <NavigationView.Header>
                <Grid ColumnSpacing="8" Padding="4,0" ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto">
                    <Border Grid.Column="0" CornerRadius="14" Padding="10,4"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                            <TextBlock Text="{Binding BackendState, Converter={StaticResource Capitalize}}"
                                       Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" CornerRadius="14" Padding="10,4"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                            <TextBlock Text="{Binding RelayState, Converter={StaticResource Capitalize}}"
                                       Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" CornerRadius="14" Padding="10,4"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <TextBlock Text="{Binding ActiveStreams}" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Grid.Column="3" Text="{Binding ProgressText}" VerticalAlignment="Center" Margin="6,0"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                    <Button Grid.Column="4" Click="Start_Click" Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE768;" FontSize="14" />
                            <TextBlock Text="Start" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="5" Content="Stop" Click="Stop_Click" />
                    <Button Grid.Column="6" Click="Restart_Click" ToolTipService.ToolTip="Restart engine">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                    </Button>
                </Grid>
            </NavigationView.Header>

            <Grid Padding="18">
                <!-- LIVE -->
                <Grid x:Name="LiveView" RowDefinitions="Auto,*">
                    <InfoBar Grid.Row="0" IsOpen="{Binding RestartNeeded}" Severity="Informational"
                             Title="Restart needed" Message="Saved engine settings apply after restart." Margin="0,0,0,12" />

                    <Grid Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding Panels}" ItemTemplate="{StaticResource PanelCardTemplate}" Margin="-6,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <tk:UniformGrid Rows="1" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                                    Visibility="{Binding PrimaryPanel, Converter={StaticResource NullToVisibility}}">
                            <FontIcon Glyph="&#xE720;" FontSize="32" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            <TextBlock Text="Waiting for voice activity…" HorizontalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- SETTINGS -->
                <ScrollViewer x:Name="SettingsView" Visibility="Collapsed" HorizontalScrollBarVisibility="Disabled">
                  <Grid Padding="0,0,4,24">
                    <StackPanel HorizontalAlignment="Stretch" MaxWidth="980" Spacing="4">
                        <InfoBar IsOpen="{Binding RestartNeeded}" Severity="Informational"
                                 Title="Restart needed" Message="Saved engine settings apply after restart." Margin="0,0,0,8" />

                        <TextBlock Text="Engine" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="2,8,0,2" />
                        <tk:SettingsCard Header="Whisper model" Description="Larger models are more accurate but slower.">
                            <ComboBox MinWidth="160" ItemsSource="{Binding WhisperModels}" SelectedItem="{Binding WhisperModel, Mode=TwoWay}" />
                        </tk:SettingsCard>
                        <tk:SettingsCard Header="Language" Description="Leave blank to auto-detect.">
                            <TextBox Width="200" PlaceholderText="auto" Text="{Binding Language, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </tk:SettingsCard>
                        <tk:SettingsCard Header="Beam size" Description="Higher values search more transcription candidates.">
                            <NumberBox Value="{Binding BeamSize, Mode=TwoWay}" Minimum="1" Maximum="10" SpinButtonPlacementMode="Compact" />
                        </tk:SettingsCard>
                        <tk:SettingsCard Header="Device" Description="{Binding GpuStatus}">
                            <ComboBox MinWidth="120" ItemsSource="{Binding Devices}" SelectedItem="{Binding Device, Mode=TwoWay}" />
                        </tk:SettingsCard>

                        <TextBlock Text="Your voice" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="2,12,0,2" />
                        <tk:SettingsExpander Header="Transcribe my own voice"
                                             Description="Capture and transcribe your microphone alongside others.">
                            <ToggleSwitch IsOn="{Binding SelfEnabled, Mode=TwoWay}" />
                            <tk:SettingsExpander.Items>
                                <tk:SettingsCard Header="Only when unmuted" IsEnabled="{Binding SelfEnabled}">
                                    <ToggleSwitch IsOn="{Binding SelfOnlyUnmuted, Mode=TwoWay}" />
                                </tk:SettingsCard>
                                <tk:SettingsCard Header="Only when Discord says I am speaking" IsEnabled="{Binding SelfEnabled}">
                                    <ToggleSwitch IsOn="{Binding SelfRequireSpeaking, Mode=TwoWay}" />
                                </tk:SettingsCard>
                                <tk:SettingsCard Header="Input device" IsEnabled="{Binding SelfEnabled}">
                                    <ComboBox MinWidth="220" ItemsSource="{Binding InputDevices}" DisplayMemberPath="Name"
                                              SelectedValuePath="Value" SelectedValue="{Binding SelfDevice, Mode=TwoWay}" />
                                </tk:SettingsCard>
                            </tk:SettingsExpander.Items>
                        </tk:SettingsExpander>

                        <TextBlock Text="Silence gating" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="2,12,0,2" />
                        <tk:SettingsCard Header="Minimum loudness" Description="Audio quieter than this is ignored (dBFS).">
                            <Slider Width="240" Minimum="-70" Maximum="-30" StepFrequency="1" Value="{Binding MinRmsDbfs, Mode=TwoWay}" />
                        </tk:SettingsCard>
                        <tk:SettingsCard Header="Silero VAD" Description="Voice-activity detection to filter non-speech.">
                            <ToggleSwitch IsOn="{Binding Vad, Mode=TwoWay}" />
                        </tk:SettingsCard>
                        <tk:SettingsCard Header="Drop phrases" Description="Comma-separated phrases to discard.">
                            <TextBox Width="280" Text="{Binding DropPhrases, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </tk:SettingsCard>

                        <TextBlock Text="Alerts" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="2,12,0,2" />
                        <tk:SettingsCard Header="Keywords" Description="Press Enter or comma to add. Each becomes a removable pill.">
                            <tk:TokenizingTextBox Width="320" ItemsSource="{Binding KeywordTokens}" TokenDelimiter=","
                                                  PlaceholderText="Add keyword" TokenItemAdding="Keywords_TokenItemAdding" />
                        </tk:SettingsCard>
                        <tk:SettingsCard Header="Play sound" Description="Play a chime when a keyword is heard.">
                            <ToggleSwitch IsOn="{Binding AlertSound, Mode=TwoWay}" />
                        </tk:SettingsCard>
                        <tk:SettingsCard Header="Highlight color" Description="Hex color used to highlight matches.">
                            <TextBox Width="140" Text="{Binding Highlight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </tk:SettingsCard>

                        <TextBlock Text="Display and overlay" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="2,12,0,2" />
                        <tk:SettingsExpander Header="Overlay and timestamps" Description="How the on-screen overlay and transcript render.">
                            <tk:SettingsExpander.Items>
                                <tk:SettingsCard Header="Show voice events">
                                    <ToggleSwitch IsOn="{Binding VoiceEvents, Mode=TwoWay}" />
                                </tk:SettingsCard>
                                <tk:SettingsCard Header="Newest on top" Description="Default direction for new transcript cards.">
                                    <ToggleSwitch IsOn="{Binding NewestAtTop, Mode=TwoWay}" />
                                </tk:SettingsCard>
                                <tk:SettingsCard Header="Show timestamps">
                                    <ToggleSwitch IsOn="{Binding ShowTimestamps, Mode=TwoWay}" />
                                </tk:SettingsCard>
                                <tk:SettingsCard Header="Timestamp format">
                                    <ComboBox MinWidth="140" ItemsSource="{Binding TimestampFormats}" SelectedItem="{Binding TimestampFormat, Mode=TwoWay}" />
                                </tk:SettingsCard>
                                <tk:SettingsCard Header="Overlay log height">
                                    <NumberBox Value="{Binding OverlayLogHeight, Mode=TwoWay}" Minimum="120" Maximum="900" SpinButtonPlacementMode="Compact" />
                                </tk:SettingsCard>
                                <tk:SettingsCard Header="Subtitle timeout (ms)">
                                    <NumberBox Value="{Binding SubtitleTimeout, Mode=TwoWay}" Minimum="500" SpinButtonPlacementMode="Compact" />
                                </tk:SettingsCard>
                                <tk:SettingsCard Header="Max blocks">
                                    <NumberBox Value="{Binding MaxBlocks, Mode=TwoWay}" Minimum="1" Maximum="20" SpinButtonPlacementMode="Compact" />
                                </tk:SettingsCard>
                                <tk:SettingsCard Header="Fade starts at">
                                    <NumberBox Value="{Binding FadeStart, Mode=TwoWay}" Minimum="1" Maximum="20" SpinButtonPlacementMode="Compact" />
                                </tk:SettingsCard>
                                <tk:SettingsCard Header="Minimum fade opacity">
                                    <NumberBox Value="{Binding MinFadeOpacity, Mode=TwoWay}" Minimum="0" Maximum="1" SmallChange="0.05" SpinButtonPlacementMode="Compact" />
                                </tk:SettingsCard>
                            </tk:SettingsExpander.Items>
                        </tk:SettingsExpander>

                        <TextBlock Text="Advanced" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="2,12,0,2" />
                        <tk:SettingsExpander Header="Advanced" Description="Engine internals — change only if you know why.">
                            <tk:SettingsExpander.Items>
                                <tk:SettingsCard Header="Compute type">
                                    <ComboBox MinWidth="160" ItemsSource="{Binding ComputeTypes}" SelectedItem="{Binding ComputeType, Mode=TwoWay}" />
                                </tk:SettingsCard>
                                <tk:SettingsCard Header="Relay port">
                                    <NumberBox Value="{Binding RelayPort, Mode=TwoWay}" Minimum="1024" Maximum="65535" SpinButtonPlacementMode="Compact" />
                                </tk:SettingsCard>
                            </tk:SettingsExpander.Items>
                        </tk:SettingsExpander>

                        <TextBlock Text="Discord sources" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="2,12,0,2" />
                        <tk:SettingsExpander Header="Connected Discord clients"
                                             Description="Most setups use one. Expand only if you run multiple Discord installs."
                                             ItemsSource="{Binding Clients}">
                            <Button Content="Refresh" Click="RefreshClients_Click" />
                            <tk:SettingsExpander.ItemTemplate>
                                <DataTemplate x:DataType="models:DiscordClientInfo">
                                    <tk:SettingsCard Header="{Binding DisplayName}" Description="{Binding StatusText}">
                                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                            <ToggleSwitch Header="Overlay" IsOn="{Binding OverlayEnabled, Mode=TwoWay}" Toggled="ClientSetting_Toggled" />
                                            <ToggleSwitch Header="My voice" IsOn="{Binding SelfEnabled, Mode=TwoWay}" Toggled="ClientSetting_Toggled" />
                                            <Button Content="{Binding ActionText}" Tag="{Binding}" Click="ClientAction_Click" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </tk:SettingsCard>
                                </DataTemplate>
                            </tk:SettingsExpander.ItemTemplate>
                        </tk:SettingsExpander>

                        <TextBlock Text="About" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="2,12,0,2" />
                        <tk:SettingsCard Header="whispercord" Description="{Binding UpdateStatus}">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="{Binding AppVersion}" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <HyperlinkButton Content="Get update" NavigateUri="https://github.com/ellypaws/whispercord/releases"
                                                 Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </tk:SettingsCard>
                        <tk:SettingsCard Header="Help and feedback" Description="Source, releases and bug reports on GitHub.">
                            <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                                <HyperlinkButton Content="GitHub" NavigateUri="https://github.com/ellypaws/whispercord" />
                                <HyperlinkButton Content="Report a bug" NavigateUri="https://github.com/ellypaws/whispercord/issues/new/choose" />
                                <HyperlinkButton Content="Issues" NavigateUri="https://github.com/ellypaws/whispercord/issues" />
                            </StackPanel>
                        </tk:SettingsCard>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
                            <Button Content="Save settings" Click="SaveSettings_Click" Style="{StaticResource AccentButtonStyle}" />
                            <Button Content="Restart engine" Click="Restart_Click" />
                        </StackPanel>
                    </StackPanel>
                  </Grid>
                </ScrollViewer>

                <!-- CONSOLE -->
                <Grid x:Name="ConsoleView" Visibility="Collapsed" RowDefinitions="Auto,*" RowSpacing="12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                        <Button Content="Copy" Click="CopyConsole_Click" />
                        <Button Content="Clear" Click="ClearConsole_Click" />
                    </StackPanel>
                    <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <ListView ItemsSource="{Binding Logs}" SelectionMode="None" FontFamily="Consolas" FontSize="12" Padding="8" />
                    </Border>
                </Grid>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
