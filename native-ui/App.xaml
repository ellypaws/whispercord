<Application
    x:Class="DiscordTranscriber.Native.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:DiscordTranscriber.Native.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <conv:AvatarImageConverter x:Key="AvatarImageConverter" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
            <conv:NullToVisibilityConverter x:Key="NullToVisibility" />
            <conv:CapitalizeConverter x:Key="Capitalize" />

            <AcrylicBrush x:Key="TransientAcrylicBrush"
                          TintColor="#2B2D31"
                          TintOpacity="0.86"
                          TintLuminosityOpacity="0.72"
                          FallbackColor="#2B2D31" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
